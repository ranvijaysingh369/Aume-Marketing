---
/**
 * /v2/shop — Order both products on one page.
 *
 * Mirrors v1 /buy structure (qty stepper + customer info form +
 * trust strip + watermark close), extended to two products.
 * Live commerce wiring is out of scope; the form swaps to a
 * confirmation panel on submit, same as v1.
 */
import V2Base from '@layouts/V2Base.astro';
import { images } from '@lib/assets';
const honeyImage = images['honey-same-bg'];
const gheeImage  = images['ghee-same-bg'];
const logo       = images['logo-3d'];
---
<V2Base
  title="Shop — aumé"
  description="Order Himalayan Clear Honey and A2 Bilona Ghee. Ships from New Jersey."
  navMode="solid"
  currentPath="/v2/shop"
>

<!-- ============================================================
     §1 PRODUCTS — two cards side by side, each with qty stepper
     ============================================================ -->
<section class="v2-shop">
  <div class="v2-shop__inner">
    <div class="v2-shop__head v2-reveal">
      <span class="v2-eyebrow v2-eyebrow--center">Order</span>
      <h1 class="v2-shop__title">Two ancestral originals.</h1>
      <p class="v2-shop__caption">
        Ships from New Jersey&nbsp;&middot;&nbsp;Free over $75&nbsp;&middot;&nbsp;Three business days
      </p>
    </div>

    <form class="v2-shop__form" id="v2-shop-form">
      <div class="v2-shop__products">
        <!-- HONEY -->
        <article class="v2-shop__product v2-reveal">
          <figure class="v2-shop__image">
            <img src={honeyImage.webp} alt={honeyImage.description} loading="eager" decoding="async" />
          </figure>
          <div class="v2-shop__product-body">
            <span class="v2-eyebrow">The Honey</span>
            <h2 class="v2-shop__product-name">Himalayan <em>Clear&nbsp;Honey.</em></h2>
            <p class="v2-shop__product-sub">
              Kashmir Valley&nbsp;&middot;&nbsp;11,000&nbsp;ft+&nbsp;&middot;&nbsp;Single Origin&nbsp;&middot;&nbsp;Raw
            </p>
            <div class="v2-shop__price-row">
              <span class="v2-shop__price">$44.99</span>
              <span class="v2-shop__unit">/ 12 oz · 340 g</span>
            </div>
            <div class="v2-shop__qty-block">
              <span class="v2-eyebrow v2-eyebrow--solo v2-shop__qty-label">Quantity</span>
              <div class="v2-shop__qty">
                <button type="button" aria-label="Decrease honey quantity" data-qty-step="-1">&minus;</button>
                <input type="number" min="0" value="1" name="honey-qty" data-price="44.99" aria-label="Honey quantity" />
                <button type="button" aria-label="Increase honey quantity" data-qty-step="1">+</button>
              </div>
            </div>
          </div>
        </article>

        <!-- GHEE -->
        <article class="v2-shop__product v2-reveal" data-delay="120">
          <figure class="v2-shop__image">
            <img src={gheeImage.webp} alt={gheeImage.description} loading="eager" decoding="async" />
          </figure>
          <div class="v2-shop__product-body">
            <span class="v2-eyebrow">The Ghee</span>
            <h2 class="v2-shop__product-name">A2 <em>Bilona&nbsp;Ghee.</em></h2>
            <p class="v2-shop__product-sub">
              A2 Beta&#8209;Casein&nbsp;&middot;&nbsp;Bilona Churned&nbsp;&middot;&nbsp;5,000&nbsp;Years
            </p>
            <div class="v2-shop__price-row">
              <span class="v2-shop__price">$25</span>
              <span class="v2-shop__unit">/ 7.9 oz · 225 g</span>
            </div>
            <div class="v2-shop__qty-block">
              <span class="v2-eyebrow v2-eyebrow--solo v2-shop__qty-label">Quantity</span>
              <div class="v2-shop__qty">
                <button type="button" aria-label="Decrease ghee quantity" data-qty-step="-1">&minus;</button>
                <input type="number" min="0" value="0" name="ghee-qty" data-price="25" aria-label="Ghee quantity" />
                <button type="button" aria-label="Increase ghee quantity" data-qty-step="1">+</button>
              </div>
            </div>
          </div>
        </article>
      </div>

      <!-- Customer info -->
      <div class="v2-shop__customer v2-reveal" data-delay="240">
        <span class="v2-eyebrow v2-eyebrow--center">Shipping</span>
        <div class="v2-shop__row">
          <label><span class="v2-eyebrow v2-eyebrow--solo">First name</span>
            <input type="text" required autocomplete="given-name" /></label>
          <label><span class="v2-eyebrow v2-eyebrow--solo">Last name</span>
            <input type="text" required autocomplete="family-name" /></label>
        </div>
        <div class="v2-shop__row v2-shop__row--single">
          <label><span class="v2-eyebrow v2-eyebrow--solo">Email</span>
            <input type="email" required autocomplete="email" placeholder="you@domain.com" /></label>
        </div>
        <div class="v2-shop__row v2-shop__row--single">
          <label><span class="v2-eyebrow v2-eyebrow--solo">Shipping address</span>
            <input type="text" required autocomplete="street-address" /></label>
        </div>
      </div>

      <!-- Total + place order -->
      <div class="v2-shop__total v2-reveal" data-delay="320">
        <div class="v2-shop__total-row">
          <span class="v2-eyebrow v2-eyebrow--solo">Total</span>
          <span class="v2-shop__total-num" id="v2-shop-total">$44.99</span>
        </div>
        <button type="submit" class="v2-cta v2-cta--shop" id="v2-shop-cta">
          Place Order
          <span class="v2-cta__pip" aria-hidden="true">↗</span>
        </button>
      </div>
    </form>

    <!-- Confirmation (swapped in on submit) -->
    <div class="v2-shop__confirmation" id="v2-shop-confirmation" hidden role="status" aria-live="polite">
      <span class="v2-eyebrow v2-eyebrow--center">Order Placed</span>
      <h2 class="v2-shop__title">Thank you.</h2>
      <p class="v2-shop__caption">
        A confirmation will arrive shortly. Your order is on its way from New Jersey.
      </p>
      <a class="v2-cta" href="/v2/" style="margin-top: 24px">
        Return Home
        <span class="v2-cta__pip" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     §2 TRUST STRIP
     ============================================================ -->
<section class="v2-trust">
  <div class="v2-trust__inner">
    <span class="v2-eyebrow v2-eyebrow--center v2-reveal">What you can count on</span>
    <div class="v2-trust__row">
      <div class="v2-trust__item v2-reveal">
        <span class="v2-eyebrow v2-eyebrow--solo">Shipping</span>
        <p class="v2-body">
          Free over $75. Otherwise $9 flat. Ships within three business days from New Jersey.
        </p>
      </div>
      <div class="v2-trust__item v2-reveal" data-delay="120">
        <span class="v2-eyebrow v2-eyebrow--solo">Returns</span>
        <p class="v2-body">
          Unopened jars returnable within 30 days. We refund the jar; we don't refund the journey.
        </p>
      </div>
      <div class="v2-trust__item v2-reveal" data-delay="240">
        <span class="v2-eyebrow v2-eyebrow--solo">Provenance</span>
        <p class="v2-body">
          Each jar signed. Trace harvester, batch, and harvest week on the back label.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     §3 WATERMARK CLOSE
     ============================================================ -->
<section class="v2-watermark" aria-hidden="true">
  <img src={logo.webp} alt="" class="v2-watermark__logo" />
  <p class="v2-watermark__line">Limited release&nbsp;&middot;&nbsp;2026 harvest</p>
</section>

</V2Base>

<style>
  /* §1 SHOP */
  .v2-shop {
    background: var(--v2-bg);
    padding: clamp(120px, 16vh, 180px) var(--tile-overlay-pad-x) clamp(72px, 10vh, 120px);
  }
  .v2-shop__inner {
    max-width: var(--container-wide);
    margin: 0 auto;
  }
  .v2-shop__head {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(48px, 7vh, 80px);
  }
  .v2-shop__title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(36px, 4.4vw, 56px);
    color: var(--v2-cream);
    margin: 0;
    text-wrap: balance;
  }
  .v2-shop__title em { font-style: italic; color: var(--v2-gold-2); font-weight: 300; }
  .v2-shop__caption {
    font-family: var(--jakarta);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--v2-beige);
    margin: 0;
  }

  .v2-shop__form { display: flex; flex-direction: column; gap: clamp(48px, 6vh, 72px); }
  .v2-shop__products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 56px);
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .v2-shop__product {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  /* Both cards use the same 2:3 portrait aspect so the row is even.
     Ghee source is 2:3 — fills naturally, no crop visible. Honey
     source is 1:1 — cover crops the cream linen edges minimally
     (the jar stays fully in frame). */
  .v2-shop__image {
    margin: 0;
    aspect-ratio: 2 / 3;
    overflow: hidden;
    background: var(--v2-bg2);
    width: 100%;
  }
  .v2-shop__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    filter: contrast(1.06) saturate(1.10);
  }
  .v2-shop__product-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .v2-shop__product-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(28px, 2.8vw, 38px);
    color: var(--v2-cream);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .v2-shop__product-name em { font-style: italic; color: var(--v2-gold-2); font-weight: 300; }
  .v2-shop__product-sub {
    font-family: var(--jakarta);
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v2-beige);
    margin: 0;
  }
  .v2-shop__price-row {
    display: flex; align-items: baseline; gap: 12px;
    margin-top: 4px;
  }
  .v2-shop__price {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 32px;
    color: var(--v2-cream);
  }
  .v2-shop__unit {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v2-beige);
  }
  .v2-shop__qty-block {
    display: flex; flex-direction: column; gap: 8px;
    margin-top: 8px;
  }
  .v2-shop__qty {
    display: flex; align-items: center;
    width: max-content;
    border: 1px solid color-mix(in oklab, var(--v2-cream) 38%, transparent);
    border-radius: 999px;
  }
  .v2-shop__qty button {
    width: 40px; height: 40px;
    font-family: var(--serif);
    font-size: 20px;
    line-height: 1;
    color: var(--v2-cream);
    transition: color var(--dur-cta) var(--ease-cinema);
  }
  .v2-shop__qty button:hover { color: var(--v2-gold); }
  .v2-shop__qty input {
    width: 48px; height: 40px;
    text-align: center;
    border: 0;
    background: transparent;
    font-family: var(--serif);
    font-size: 18px;
    color: var(--v2-cream);
    -moz-appearance: textfield;
    appearance: textfield;
  }
  .v2-shop__qty input::-webkit-outer-spin-button,
  .v2-shop__qty input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* Customer info */
  .v2-shop__customer {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: clamp(32px, 4vh, 48px);
    border-top: 1px solid color-mix(in oklab, var(--v2-cream) 12%, transparent);
  }
  .v2-shop__customer > .v2-eyebrow { margin-bottom: 8px; }
  .v2-shop__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .v2-shop__row--single { grid-template-columns: 1fr; }
  .v2-shop__row label {
    display: flex; flex-direction: column; gap: 6px;
  }
  .v2-shop__row input {
    font-family: var(--jakarta);
    font-size: 15px;
    padding: 14px 16px;
    border: 1px solid color-mix(in oklab, var(--v2-cream) 22%, transparent);
    background: var(--v2-bg2);
    color: var(--v2-cream);
    transition: border-color var(--dur-cta) var(--ease-cinema);
  }
  .v2-shop__row input:focus {
    outline: none;
    border-color: var(--v2-gold);
  }

  /* Total + CTA */
  .v2-shop__total {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: clamp(28px, 4vh, 40px);
    border-top: 1px solid color-mix(in oklab, var(--v2-cream) 12%, transparent);
  }
  .v2-shop__total-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .v2-shop__total-num {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 36px;
    color: var(--v2-cream);
  }
  .v2-cta--shop {
    align-self: stretch;
    justify-content: center;
    padding: 18px 26px 18px 32px;
    font-size: 12px;
  }

  /* Confirmation */
  .v2-shop__confirmation {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: clamp(48px, 8vh, 96px) 0;
  }

  @media (max-width: 900px) {
    .v2-shop { padding: clamp(96px, 14vh, 140px) 24px 64px; }
    .v2-shop__products { grid-template-columns: 1fr; }
    .v2-shop__row { grid-template-columns: 1fr; }
  }

  /* §2 TRUST STRIP */
  .v2-trust {
    background: var(--v2-bg2);
    padding: 64px var(--tile-overlay-pad-x);
    border-top: 1px solid color-mix(in oklab, var(--v2-cream) 8%, transparent);
  }
  .v2-trust__inner {
    max-width: var(--container);
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  .v2-trust__row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    text-align: left;
    width: 100%;
  }
  .v2-trust__item {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .v2-trust__item .v2-body {
    font-size: 13px;
    line-height: 1.65;
    margin: 0;
  }
  @media (max-width: 760px) {
    .v2-trust { padding: 48px 24px; }
    .v2-trust__row { grid-template-columns: 1fr; gap: 24px; }
  }

  /* §3 WATERMARK */
  .v2-watermark {
    background: var(--v2-bg);
    padding: clamp(56px, 8vh, 96px) var(--tile-overlay-pad-x);
    text-align: center;
  }
  .v2-watermark__logo {
    width: clamp(160px, 18vw, 240px);
    opacity: 0.12;
    margin: 0 auto;
  }
  .v2-watermark__line {
    margin-top: 16px;
    font-family: var(--jakarta);
    font-size: 11px;
    letter-spacing: 0.40em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--v2-beige) 75%, transparent);
  }
</style>

<script>
  // Quantity steppers
  document.querySelectorAll<HTMLButtonElement>('[data-qty-step]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.qtyStep || '0', 10);
      const input = btn.parentElement?.querySelector<HTMLInputElement>('input');
      if (!input) return;
      const cur = parseInt(input.value, 10) || 0;
      input.value = String(Math.max(0, cur + step));
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  });

  // Live total
  const inputs = document.querySelectorAll<HTMLInputElement>('input[name$="-qty"]');
  const totalEl = document.getElementById('v2-shop-total');
  const ctaEl = document.getElementById('v2-shop-cta') as HTMLButtonElement | null;
  function recalc() {
    let total = 0;
    inputs.forEach((i) => {
      const qty = parseInt(i.value, 10) || 0;
      const price = parseFloat(i.dataset.price || '0');
      total += qty * price;
    });
    const formatted = `$${total.toFixed(2).replace(/\.00$/, '')}`;
    if (totalEl) totalEl.textContent = formatted;
    if (ctaEl) ctaEl.toggleAttribute('disabled', total <= 0);
  }
  inputs.forEach((i) => i.addEventListener('input', recalc));
  recalc();

  // Form submit → confirmation
  const form = document.getElementById('v2-shop-form') as HTMLFormElement | null;
  const conf = document.getElementById('v2-shop-confirmation') as HTMLElement | null;
  if (form && conf) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.hidden = true;
      conf.hidden = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
