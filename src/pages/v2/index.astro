---
/**
 * /v2/ — Home (4 vertical tiles, dark-cinema)
 *
 *   §1 Hero            Himalayan first-light video. "aumé" wordmark
 *                      RISES from below to optical center on page load.
 *                      Eyebrow caps "FROM THE EARTH" appears above.
 *   §2 Honey tile      dancer-honey backdrop (cinematic dark, falling
 *                      honey strands). Same composition as §3.
 *   §3 Ghee tile       PLACEHOLDER (honey-drinking-flower) until the
 *                      real ghee tile lands. Different scene from §2
 *                      so the eye doesn't read the page as repeating.
 *   §4 Closing         dark surface (single page surface — no cream
 *                      break). Italic centered "From the Earth.",
 *                      sub line + gold rule + dark footer below.
 *
 * Hard rules from docs/v2-build-brief.md §2.2:
 *   - hero text is abstract — never names a place
 *   - ghee never claims mountains anywhere on this page
 * Hard rules from ui-ux-pro-max:
 *   - no text-shadows on text
 *   - single dark surface — no section-level bg color changes
 *   - eyebrows ALL CAPS gold tracked 0.22em above every Cormorant headline
 */
import V2Base from '@layouts/V2Base.astro';
import { videos } from '@lib/assets';
const heroVid  = videos['aume-hero'];
const honeyVid = videos['honey-tile'];     // points at dancer-honey now
const gheeVid  = videos['ghee-tile'];      // placeholder until real ghee delivered
---
<V2Base
  title="aumé — From the Earth"
  description="Himalayan Clear Honey + A2 Bilona Ghee. Two ancestral originals. From the Earth."
  navMode="over-hero"
  currentPath="/v2/"
>

<!-- ============================================================
     §1 HERO — Himalayan first-light. Wordmark rises from below
     to optical center on page load.
     ============================================================ -->
<section class="v2-hero" data-tile-video-host>
  <video
    class="v2-hero__video"
    data-tile-video
    autoplay muted loop playsinline preload="metadata"
    poster={heroVid.poster}
    disablepictureinpicture disableremoteplayback
    aria-hidden="true"
  >
    <source src={heroVid.src720} type="video/mp4" media="(max-width: 768px)" />
    <source src={heroVid.src} type="video/mp4" />
  </video>
  <div class="v2-hero__scrim" aria-hidden="true"></div>
  <div class="v2-tile__frame" aria-hidden="true"></div>

  <div class="v2-tile__index">
    <span>N° 01 · The Pairing</span>
    <span class="v2-tile__index-line" aria-hidden="true"></span>
  </div>

  <!-- Hero copy intentionally omitted — the From-the-Earth video
       has the wordmark + tagline baked in, so any HTML overlay
       would double up. The video IS the lockup.
       Semantic <h1> for SEO/a11y is provided as a visually-hidden
       label below. -->
  <h1 class="v2-hero__sr">aumé — From the Earth</h1>
</section>

<!-- ============================================================
     §2 THE HONEY — sub-section sized (~62vh), independent block
     ============================================================ -->
<section class="v2-tile v2-tile--sub" data-tile-video-host id="the-honey">
  <video
    class="v2-tile__video"
    data-tile-video
    autoplay muted loop playsinline preload="metadata"
    poster={honeyVid.poster}
    disablepictureinpicture disableremoteplayback
    aria-hidden="true"
  >
    <source src={honeyVid.src720} type="video/mp4" media="(max-width: 768px)" />
    <source src={honeyVid.src} type="video/mp4" />
  </video>
  <div class="v2-tile__scrim" aria-hidden="true"></div>
  <div class="v2-tile__frame" aria-hidden="true"></div>

  <div class="v2-tile__index">
    <span>N° 02 · The Honey</span>
    <span class="v2-tile__index-line" aria-hidden="true"></span>
  </div>

  <div class="v2-tile__copy">
    <span class="v2-eyebrow v2-reveal" data-delay="0">The&nbsp;Honey</span>
    <h2 class="v2-tile__title v2-reveal" data-delay="120">
      Himalayan <em>Clear&nbsp;Honey.</em>
    </h2>
    <p class="v2-tile__sub v2-reveal" data-delay="160">
      Kashmir Valley&nbsp;&middot;&nbsp;11,000&nbsp;ft+&nbsp;&middot;&nbsp;Single Origin&nbsp;&middot;&nbsp;Raw
    </p>
    <div class="v2-tile__price v2-reveal" data-delay="240">
      <span class="v2-tile__price-num">$44.99</span>
      <span class="v2-tile__price-unit">/ 12 oz · 340 g</span>
    </div>
    <div class="v2-tile__ctas v2-reveal" data-delay="320">
      <a class="v2-cta" href="/buy">
        Add to Cart
        <span class="v2-cta__pip" aria-hidden="true">↗</span>
      </a>
      <a class="v2-link" href="/the-honey">
        The Story
        <span class="v2-link__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     §3 THE GHEE — sub-section sized (~62vh), independent block.
     Hard rule: ghee never claims mountains on this page.
     ============================================================ -->
<section class="v2-tile v2-tile--sub" data-tile-video-host id="the-ghee">
  <video
    class="v2-tile__video"
    data-tile-video
    autoplay muted loop playsinline preload="metadata"
    poster={gheeVid.poster}
    disablepictureinpicture disableremoteplayback
    aria-hidden="true"
  >
    <source src={gheeVid.src720} type="video/mp4" media="(max-width: 768px)" />
    <source src={gheeVid.src} type="video/mp4" />
  </video>
  <div class="v2-tile__scrim" aria-hidden="true"></div>
  <div class="v2-tile__frame" aria-hidden="true"></div>

  <div class="v2-tile__index">
    <span>N° 03 · The Ghee</span>
    <span class="v2-tile__index-line" aria-hidden="true"></span>
  </div>

  <div class="v2-tile__copy">
    <span class="v2-eyebrow v2-reveal" data-delay="0">The&nbsp;Ghee</span>
    <h2 class="v2-tile__title v2-reveal" data-delay="120">
      A2 <em>Bilona&nbsp;Ghee.</em>
    </h2>
    <p class="v2-tile__sub v2-reveal" data-delay="160">
      A2 Beta&#8209;Casein&nbsp;&middot;&nbsp;Bilona Churned&nbsp;&middot;&nbsp;5,000&nbsp;Years
    </p>
    <div class="v2-tile__price v2-reveal" data-delay="240">
      <span class="v2-tile__price-num">$25</span>
      <span class="v2-tile__price-unit">/ 7.9 oz · 225 g</span>
    </div>
    <div class="v2-tile__ctas v2-reveal" data-delay="320">
      <a class="v2-cta" href="/v2/the-ghee">
        Add to Cart
        <span class="v2-cta__pip" aria-hidden="true">↗</span>
      </a>
      <a class="v2-link" href="/v2/the-ghee">
        The Story
        <span class="v2-link__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<!-- ============================================================
     §4 CLOSING — DARK surface (single page surface, no break).
     Italic Cormorant centered, no CTAs.
     ============================================================ -->
<section class="v2-closing">
  <div class="v2-closing__inner">
    <span class="v2-eyebrow v2-eyebrow--center v2-eyebrow--solo v2-reveal">A&nbsp;Morning&nbsp;Ritual</span>
    <p class="v2-closing__line v2-reveal" data-delay="120">
      <em>From&nbsp;the&nbsp;Earth.</em>
    </p>
    <p class="v2-closing__sub v2-reveal" data-delay="240">
      Two ancestral originals.&nbsp;&nbsp;One mission.
    </p>
    <span class="v2-closing__rule v2-reveal" data-delay="320" aria-hidden="true"></span>
  </div>
</section>

</V2Base>

<style>
  /* ============================================================
   * §1 HERO — center-rising wordmark on dark mountain footage.
   * The wordmark rises from translateY(56px) to its final position
   * at optical center. Eyebrow above, gold hairline below — the
   * lockup is one stamped mark.
   * ============================================================ */
  .v2-hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    width: 100vw;
    overflow: hidden;
    background: var(--v2-bg);
    isolation: isolate;
  }
  /* Visually-hidden semantic h1 for SEO + a11y. The video has the
     wordmark + tagline baked in, so we don't render text overlay. */
  .v2-hero__sr {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    border: 0;
    white-space: nowrap;
  }
  .v2-hero__video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    transform: translateZ(0);
    backface-visibility: hidden;
    /* No CSS filter — see .v2-tile__video comment. Hero footage
       is already first-light moody; the scrim handles the rest. */
  }
  /* Hero scrim — center radial darken so cream wordmark reads on
     the mountain mid-tones (no text-shadow). All-over mocha tint
     matched to the §2/§3 tile scrim so the four sections read as
     one continuous twilight palette. */
  /* Hero scrim — lighter, since the wordmark is baked into the
     video and we don't need to lift cream copy off the mid-tones.
     Just a soft top + bottom darken plus the warm-amber wash for
     chromatic continuity with the §2 / §3 tiles. */
  .v2-hero__scrim {
    position: absolute; inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 40% at 82% 12%, rgba(197, 149, 42, 0.10) 0%, transparent 70%),
      linear-gradient(
        to bottom,
        rgba(6, 5, 4, 0.18) 0%,
        transparent 35%,
        transparent 65%,
        rgba(6, 5, 4, 0.32) 100%
      );
  }

  /* Hero copy — overlay centered (per founder request). Eyebrow
     above wordmark, hairline below. The whole lockup centers
     horizontally, sits ~6vh above optical center for visual weight. */
  .v2-hero__copy {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    pointer-events: none;
    padding-bottom: 6vh;
    gap: 8px;
  }
  /* Tagline now appears AFTER the wordmark+hairline lockup settles —
     fires at 4000ms, just after the hairline finishes drawing (3900ms).
     Sits beneath the hairline with a small visual breath above. */
  .v2-hero__eyebrow {
    margin-top: 6px;
    opacity: 0;
    animation: v2-hero-fade 1100ms var(--ease-cinema) 4000ms forwards;
  }

  /* Wordmark — char-split rise. Each glyph rises from
     translateY(56px) scale(0.94) on a stagger keyed by --ch
     (90ms apart). Choreography starts 800ms; last glyph settles
     at ~3.47s (matches brief §2.4 "settles at 3.2s" spec). */
  .v2-hero__brand {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: var(--t-display);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--v2-cream);
    margin: 0;
  }
  .v2-hero__brand-char {
    display: inline-block;
    color: var(--v2-cream);
    background: linear-gradient(180deg, var(--v2-cream) 30%, var(--v2-gold-2) 100%);
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0;
    transform: translateY(56px) scale(0.94);
    animation:
      v2-hero-rise var(--dur-rise) var(--ease-cinema)
        calc(800ms + var(--ch) * 90ms)
        both;
  }
  @supports not ((-webkit-background-clip: text) or (background-clip: text)) {
    .v2-hero__brand-char {
      background: none;
      -webkit-text-fill-color: var(--v2-cream);
      color: var(--v2-cream);
    }
  }

  .v2-hero__hairline {
    display: block;
    width: 0;
    height: 1px;
    background: var(--v2-gold);
    margin: 14px 0 0;
    box-shadow: 0 0 18px rgba(197, 149, 42, 0.45);
    animation: v2-hero-hairline 900ms var(--ease-cinema) 3000ms both;
  }

  .v2-hero .v2-tile__index {
    opacity: 0;
    animation: v2-hero-fade 1200ms var(--ease-cinema) 1800ms forwards;
  }

  @keyframes v2-hero-rise {
    0%   { opacity: 0; transform: translateY(56px) scale(0.94); }
    100% { opacity: 1; transform: translateY(0)    scale(1.00); }
  }
  @keyframes v2-hero-hairline {
    0%   { width: 0; }
    100% { width: 84px; }
  }
  @keyframes v2-hero-fade {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .v2-hero__brand-char {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .v2-hero__hairline { animation: none; width: 84px; }
    .v2-hero__eyebrow,
    .v2-hero .v2-tile__index {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 760px) {
    .v2-hero__brand { font-size: clamp(64px, 18vw, 88px); }
  }

  /* ============================================================
   * §4 CLOSING — DARK surface (single page surface).
   * Italic Cormorant, centered, gold hairline.
   * ============================================================ */
  .v2-closing {
    background: var(--v2-bg);
    padding: var(--pad-cinema-y) var(--tile-overlay-pad-x);
    position: relative;
    z-index: var(--z-content);
    /* Subtle radial glow from above — echoes the sunrise warmth
       so the closing still reads as connected to the hero. */
    background-image:
      radial-gradient(ellipse 80% 70% at 50% -10%, rgba(197, 149, 42, 0.06) 0%, transparent 60%);
  }
  .v2-closing__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(22px, 2.6vw, 32px);
  }
  .v2-closing__line {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(44px, 6vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--v2-cream);
    margin: 0;
    text-wrap: balance;
  }
  .v2-closing__line em {
    font-style: italic;
    background: linear-gradient(180deg, var(--v2-cream) 30%, var(--v2-gold-2) 100%);
    -webkit-background-clip: text;
            background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .v2-closing__sub {
    font-family: var(--jakarta);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.40em;
    text-transform: uppercase;
    color: var(--v2-gold);
    margin: 0;
  }
  .v2-closing__rule {
    width: 56px;
    height: 1px;
    background: var(--v2-gold);
    opacity: 0.6;
  }
  @media (max-width: 760px) {
    .v2-closing__line { font-size: clamp(34px, 9vw, 44px); }
  }
</style>
