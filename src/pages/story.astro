---
/**
 * /story — Story
 * Phase-6: §1 hero refactored to fixed full-bleed video backdrop
 *          (matches `/` pattern). Backdrop = honey-drinking-flower.mp4
 *          (vid 4) — wooden honey dipper, gypsophila in vase.
 *
 * Sources of truth: content-brief.md §C /story, structure.md §A /story
 */
import Base from '@layouts/Base.astro';
import { videos, images } from '@lib/assets';
const heroVid = videos['honey-drinking-flower'];
const jarFB   = images['honey-front-and-back']; // labels visible — earns the "anatomy of a jar" slot in §2
---
<Base
  title="The Story — aumé"
  description="Where the honey comes from, and why nothing about its making is industrial."
  navMode="over-hero"
  currentPath="/story"
>

<!-- §1 HERO — full-bleed backdrop -->
<section class="story-hero" data-bg-video-host>
  <video
    class="story-hero__video bg-video"
    data-bg-video
    autoplay muted loop playsinline preload="metadata"
    poster={heroVid.poster}
    disablepictureinpicture disableremoteplayback
    aria-hidden="true"
  >
    <source src={heroVid.src720} type="video/mp4" media="(max-width: 768px)" />
    <source src={heroVid.src} type="video/mp4" />
  </video>
  <div class="story-hero__vignette" aria-hidden="true"></div>
  <div class="story-hero__copy">
    <span class="eyebrow eyebrow--cream eyebrow--solo">The Story</span>
    <h1 class="h1 story-hero__title">
      Where purity is <em>not an option —</em><br/>it is the only way.
    </h1>
  </div>
  <div class="story-hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <span class="story-hero__scroll-line"></span>
  </div>
</section>

<!-- §2 THE VALLEY (annotated jar + 3-stat row) -->
<section class="valley">
  <div class="valley__inner">
    <div class="valley__copy">
      <span class="eyebrow fade-up">Kashmir Valley &nbsp;·&nbsp; 11,000 ft+</span>
      <h2 class="h2 fade-up" style="margin-top:16px">The air is clean. <em>The meadows untouched.</em></h2>
      <p class="body fade-up" style="margin-top:20px">
        Kashmir's Himalayan valleys sit above 11,000 feet. The air is clean.
        The wildflower meadows untouched. The bees that forage these blooms
        produce a honey so rare, so clear, it crystallises slowly over months
        like liquid amber — a signal of purity, not a defect. We don't blend.
        We don't shortcut altitude. The valley produces what it produces;
        we ship what it gives us.
      </p>
      <ul class="valley__stats fade-up">
        <li><span class="numeric">11K&nbsp;ft</span><span>Altitude</span></li>
        <li><span class="numeric">48&nbsp;hrs</span><span>Source to seal</span></li>
        <li><span class="numeric">100%</span><span>Raw, single origin</span></li>
      </ul>
    </div>
    <figure class="valley__jar fade-up">
      <img src={jarFB.webp} alt={jarFB.description} loading="lazy" decoding="async" />
    </figure>
  </div>
</section>

<!-- §3 THE PROCESS — copy-only. §2 already showed the labelled jar; the
     three process steps don't need a fourth jar shot beside them. -->
<section class="process process--copy-only">
  <div class="process__inner">
    <div class="process__copy">
      <span class="eyebrow fade-up">The Process</span>
      <h2 class="h2 fade-up" style="margin-top:16px">No heat. <em>No filter. No press.</em></h2>
      <ol class="process__steps">
        <li class="fade-up">
          <span class="process__step">Foraged.</span>
          Cold extracted by hand from wildflower meadows above 11,000 feet.
        </li>
        <li class="fade-up">
          <span class="process__step">Filtered.</span>
          Strained slowly through linen at ambient temperature — never heated,
          never pasteurised, never blended.
        </li>
        <li class="fade-up">
          <span class="process__step">Finished.</span>
          Hand decanted into 12 ounce glass within 48 hours of collection,
          sealed by hand. The same hands that harvest it finish it.
        </li>
      </ol>
    </div>
  </div>
</section>

<!-- §4 CLOSING LINE -->
<section class="story-closing">
  <blockquote class="story-closing__q fade-up">
    <p>"The quality of what you put into your body is a conversation you have with your future self."</p>
  </blockquote>
</section>

</Base>

<style>
  /* ============================================================
   * §1 HERO — FULL-BLEED BACKDROP (matches `/` pattern)
   * ============================================================ */
  .story-hero {
    position: relative;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background: var(--mocha);
  }
  .story-hero__video {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    object-position: center;
    z-index: var(--z-bg);
  }
  .story-hero__vignette {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    height: 100vh;
    z-index: calc(var(--z-bg) + 1);
    pointer-events: none;
    background:
      radial-gradient(ellipse 65% 55% at 22% 88%, rgba(0,0,0,0.65) 0%, transparent 70%),
      radial-gradient(ellipse 45% 35% at 88% 88%, rgba(0,0,0,0.42) 0%, transparent 70%),
      linear-gradient(
        to bottom,
        transparent 0%,
        transparent 40%,
        rgba(0, 0, 0, 0.40) 78%,
        rgba(0, 0, 0, 0.65) 100%
      );
  }
  .story-hero__copy {
    position: absolute;
    left: 48px;
    bottom: 48px;
    z-index: calc(var(--z-bg) + 2);
    color: var(--cream);
    max-width: 760px;
  }
  .story-hero__title {
    color: var(--cream);
    margin-top: 16px;
    text-shadow:
      0 2px 8px rgba(0, 0, 0, 0.75),
      0 4px 32px rgba(0, 0, 0, 0.55);
  }
  .story-hero__copy .eyebrow {
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.75),
      0 1px 12px rgba(0, 0, 0, 0.55);
  }
  .story-hero__title em { color: var(--gold-light, #E2C98A); }
  .story-hero__scroll {
    position: absolute;
    right: 48px;
    bottom: 48px;
    z-index: calc(var(--z-bg) + 2);
    display: flex; align-items: center; gap: 14px;
    color: rgba(247, 240, 230, 0.92);
    font-size: 9px; letter-spacing: 0.40em; text-transform: uppercase;
    text-shadow:
      0 1px 4px rgba(0, 0, 0, 0.7),
      0 1px 12px rgba(0, 0, 0, 0.5);
  }
  .story-hero__scroll-line {
    width: 64px; height: 1px;
    background: var(--gold);
    position: relative; overflow: hidden;
  }
  .story-hero__scroll-line::before {
    content: '';
    position: absolute; left: -40%; top: 0;
    width: 40%; height: 100%;
    background: linear-gradient(90deg, transparent, var(--cream) 50%, transparent);
    animation: story-scroll-cue 2.6s var(--ease-out-expo) infinite;
  }
  @keyframes story-scroll-cue { to { left: 120%; } }
  @media (max-width: 900px) {
    .story-hero__copy   { left: 24px; bottom: 32px; }
    .story-hero__scroll { right: 24px; bottom: 32px; }
  }

  /* ============================================================
   * §2 VALLEY — solid bg paints OVER the fixed video
   * ============================================================ */
  .valley {
    background: var(--cream);
    padding: var(--pad-section-y) var(--pad-section-x);
    position: relative;
    z-index: var(--z-content);
  }
  .valley__inner {
    display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
    max-width: var(--container);
    margin: 0 auto;
    align-items: center;
  }
  /* honey-front-and-back is a 1:1 square — match the container so the
     image fills edge-to-edge with no padding gutter. */
  .valley__jar { aspect-ratio: 1/1; overflow: hidden; margin: 0; }
  .valley__jar img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .valley__stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--cream3);
  }
  .valley__stats li { display: flex; flex-direction: column; gap: 4px; }
  .valley__stats .numeric { font-size: 28px; color: var(--gold); line-height: 1; }
  .valley__stats span:last-child { font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-muted); }
  @media (max-width: 900px) {
    .valley__inner { grid-template-columns: 1fr; gap: 32px; }
  }

  /* §3 PROCESS — copy-only single column */
  .process {
    background: var(--cream2);
    padding: var(--pad-section-y) var(--pad-section-x);
    position: relative;
    z-index: var(--z-content);
  }
  .process__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .process__steps { display: flex; flex-direction: column; gap: 20px; margin-top: 24px; max-width: 52ch; }
  .process__steps li {
    font-size: var(--t-body); line-height: 1.65; color: var(--text-body);
    padding-left: 20px;
    border-left: 1px solid var(--gold);
  }
  .process__step {
    font-family: var(--serif); font-style: italic;
    color: var(--mocha);
    margin-right: 6px;
  }

  /* §4 CLOSING */
  .story-closing {
    background: var(--mocha);
    padding: 80px var(--pad-section-x);
    text-align: center;
    position: relative;
    z-index: var(--z-content);
  }
  .story-closing__q {
    font-family: var(--serif); font-style: italic; font-weight: 300;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.45;
    color: var(--cream);
    max-width: 720px; margin: 0 auto;
  }
</style>
